# ─────────────────────────────────────────────────────────────────────────────
# QueenSync — environment variables
# Copy this to `.env` (or set in Replit Secrets) and fill in real values.
# Most values fall back to mock mode so the app boots without any secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Required by the API server (Replit provides this automatically when a
# Postgres database is attached).
DATABASE_URL=postgres://user:pass@host:5432/queensync

# Public base URL used to build callbackUrl values for external arms.
# Should be the externally reachable URL of *this* control plane
# (e.g. https://queensync.replit.app). When unset, callback URLs default
# to http://localhost:8080.
QUEENSYNC_BASE_URL=
# Legacy alias — still honoured if QUEENSYNC_BASE_URL is unset.
QUEENSYNC_PUBLIC_BASE_URL=

# ── External arm authentication (outbound dispatch) ─────────────────────────
# When an arm is onboarded with authMethod=api_key, the dispatcher attaches
# `X-API-Key: $QUEENSYNC_API_KEY`. For authMethod=bearer or jwt it attaches
# `Authorization: Bearer $QUEENSYNC_API_KEY`. authMethod=none attaches nothing.
QUEENSYNC_API_KEY=

# ── Callback authentication (inbound /api/tasks/:id/callback) ───────────────
# Preferred: HMAC shared secret. The dispatcher signs each task with
# HMAC-SHA256(taskId:status) using this secret and ships the expected
# signatures via X-QueenSync-Completed-Signature / X-QueenSync-Failed-Signature
# headers. The arm must echo the matching signature back as
# X-QueenSync-Signature: sha256=<hex>.
QUEENSYNC_CALLBACK_SECRET=

# Fallback: shared bearer token. When QUEENSYNC_CALLBACK_SECRET is unset,
# callbacks (and any future admin routes) require Authorization: Bearer <token>.
QUEENSYNC_ADMIN_TOKEN=

# ── Outbound URL guard (SSRF protection) ────────────────────────────────────
# By default, outbound URLs (arm endpointUrl, heartbeatUrl, dispatch) reject
# loopback and RFC1918 private hosts. Override with an explicit allowlist:
QUEENSYNC_ALLOWED_HOSTS=radio.ninja-portal.com,observatory.ninja-portal.com
# Or, for local development only, allow private/loopback targets:
QUEENSYNC_ALLOW_PRIVATE_HOSTS=false

# ── Adapters (Radio + Observatory) ──────────────────────────────────────────
# Both adapters fall back to mock mode when unset.
RADIO_BASE_URL=https://radio.ninja-portal.com
OBSERVATORY_BASE_URL=https://observatory.ninja-portal.com

# ── Server ports (Replit assigns automatically) ─────────────────────────────
PORT=
