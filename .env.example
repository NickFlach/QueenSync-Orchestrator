# ─────────────────────────────────────────────────────────────────────────────
# QueenSync — environment variables
#
# Copy this to `.env` (or set in Replit Secrets) and fill in real values.
# Most values fall back to mock mode so the app boots without any secrets.
#
# ─── Required for production deploy ──────────────────────────────────────────
#   DATABASE_URL                  (Replit provides automatically)
#   QUEENSYNC_BASE_URL            public URL of the deployed control plane
#   QUEENSYNC_CALLBACK_SECRET     HMAC secret so external arms can be trusted
#   QUEENSYNC_ALLOWED_HOSTS       allowlist of arm hosts (SSRF guard)
#
# ─── Required only if external arms need auth headers ────────────────────────
#   QUEENSYNC_API_KEY             outbound bearer / api-key for arms
#
# ─── Optional / mock-mode dev ────────────────────────────────────────────────
#   QUEENSYNC_PUBLIC_BASE_URL     legacy alias for QUEENSYNC_BASE_URL
#   QUEENSYNC_ADMIN_TOKEN         bearer fallback when CALLBACK_SECRET unset
#   QUEENSYNC_ALLOW_PRIVATE_HOSTS local dev only — disables the private-host
#                                 SSRF guard
#   RADIO_BASE_URL                live Radio endpoint (mock fallback)
#   OBSERVATORY_BASE_URL          live Observatory endpoint (mock fallback)
#   PORT                          Replit assigns automatically
# ─────────────────────────────────────────────────────────────────────────────

# Required by the API server (Replit provides this automatically when a
# Postgres database is attached).
DATABASE_URL=postgres://user:pass@host:5432/queensync

# Public base URL used to build callbackUrl values for external arms.
# Should be the externally reachable URL of *this* control plane
# (e.g. https://ninja-portal.com). When unset, callback URLs default
# to http://localhost:8080.
QUEENSYNC_BASE_URL=
# Legacy alias — still honoured if QUEENSYNC_BASE_URL is unset.
QUEENSYNC_PUBLIC_BASE_URL=

# ── External arm authentication (outbound dispatch) ─────────────────────────
# When an arm is onboarded with authMethod=api_key, the dispatcher attaches
# `X-API-Key: $QUEENSYNC_API_KEY`. For authMethod=bearer or jwt it attaches
# `Authorization: Bearer $QUEENSYNC_API_KEY`. authMethod=none attaches nothing.
QUEENSYNC_API_KEY=

# ── Callback authentication (inbound /api/tasks/:id/callback) ───────────────
# Preferred: HMAC shared secret. The dispatcher signs each task with
# HMAC-SHA256(taskId:status) using this secret and ships the expected
# signatures via X-QueenSync-Completed-Signature / X-QueenSync-Failed-Signature
# headers. The arm must echo the matching signature back as
# X-QueenSync-Signature: sha256=<hex>.
QUEENSYNC_CALLBACK_SECRET=

# Fallback: shared bearer token. When QUEENSYNC_CALLBACK_SECRET is unset,
# callbacks (and any future admin routes) require Authorization: Bearer <token>.
QUEENSYNC_ADMIN_TOKEN=

# ── Oracle-admin shim (Wave 3) ──────────────────────────────────────────────
# HMAC-SHA256 shared secret used to sign dispatches sent to the oracle-admin
# arm (type="oracle_admin"). The shim verifies
# `X-QueenSync-Body-Signature: sha256=<hex>` over `<timestamp>:<body>` with
# `X-QueenSync-Timestamp: <unix_ms>` (±5 min replay window). MUST be set
# before exposing the shim publicly — without it, dispatches go unsigned and
# the shim refuses them.
QUEENSYNC_ORACLE_ADMIN_HMAC_SECRET=
# Public dispatch URL of the oracle-admin shim (where QueenSync POSTs).
# MUST be HTTPS in production — HMAC-only over plain HTTP is replayable by
# anyone who can observe traffic within the ±5min timestamp window. Either
# expose the shim behind a TLS-terminating reverse proxy (nginx/caddy) or
# bind it to localhost behind a Tailscale/Wireguard tunnel.
QUEENSYNC_ORACLE_ADMIN_URL=https://oracle-admin.ninja-portal.com/dispatch
# Heartbeat probe URL for the oracle-admin shim (also HTTPS).
QUEENSYNC_ORACLE_ADMIN_HEARTBEAT_URL=https://oracle-admin.ninja-portal.com/healthz
# Bind host for the shim itself. Defaults to 127.0.0.1 (loopback) so the
# shim is reachable only via a TLS-terminating reverse proxy on the same
# host, or via a private tunnel that forwards to localhost. Set to
# 0.0.0.0 ONLY when the shim is on a trusted private network with the
# public firewall closed to its port.
ORACLE_ADMIN_HOST=127.0.0.1

# ── Wave 3 seed gating ──────────────────────────────────────────────────────
# When `true`/`1`, also seed the legacy mock arms (architect_01, atelier_01,
# signal_keeper_01, memory_keeper_01, auditor_01) alongside the real arms
# (radio, observatory, kannaka-prime, swarm-worker, oracle-admin). Useful
# for the demo set; keep unset in production.
QUEENSYNC_SEED_MOCK_ARMS=

# ── Heartbeat scheduler ─────────────────────────────────────────────────────
# Number of milliseconds an arm's `lastHeartbeat` may lag before the
# scheduler marks it `offline`. Default 180000 (3 minutes). Sweeper runs
# every 60 seconds.
QUEENSYNC_ARM_STALE_MS=

# ── Outbound URL guard (SSRF protection) ────────────────────────────────────
# By default, outbound URLs (arm endpointUrl, heartbeatUrl, dispatch) reject
# loopback and RFC1918 private hosts. Override with an explicit allowlist:
QUEENSYNC_ALLOWED_HOSTS=radio.ninja-portal.com,observatory.ninja-portal.com,170.9.238.136
# Or, for local development only, allow private/loopback targets:
QUEENSYNC_ALLOW_PRIVATE_HOSTS=false

# ── Adapters (Radio + Observatory) ──────────────────────────────────────────
# Both adapters now hit live endpoints by default. Per-call graceful
# degradation: if a request fails, the in-memory last-success cache is served
# (mode=stale). With no cache yet, mock data is served (mode=mock).
# OBSERVATORY_BASE_URL is also used by the /api/observatory/state bridge that
# powers the Hologram TV view (live HRM / consciousness snapshot).
# To use the raw Oracle IP for the observatory, set:
#   OBSERVATORY_BASE_URL=http://170.9.238.136:3334
#   QUEENSYNC_ALLOW_HTTP=true
RADIO_BASE_URL=https://radio.ninja-portal.com
OBSERVATORY_BASE_URL=https://observatory.ninja-portal.com

# Force mock mode for both adapters (dev fallback when the constellation is
# offline). Health is reported as mode=forced_mock and the UI shows a badge.
QUEENSYNC_FORCE_MOCK=false

# Floor-reactions poller (Wave 1: HTTP poll until Wave 2 wires NATS).
# Defaults to 1000ms so 🪶 reactions appear in the Signal Feed within ~1s.
QUEENSYNC_FLOOR_POLL_MS=1000
QUEENSYNC_DISABLE_FLOOR_POLL=false

# Maximum age (ms) for the in-memory last-success cache to be served as
# `mode=stale` on adapter failure. Past this age the adapter falls back to
# `mode=mock`. Default 5 minutes. Set to 0 to disable the bound (unbounded).
QUEENSYNC_STALE_MAX_AGE_MS=300000

# ── NATS subscription (Wave 2) ──────────────────────────────────────────────
# QueenSync subscribes to the Kannaka constellation bus to ingest live signals
# (dreams, consciousness updates, audience reactions, exemplars, presence).
# When NATS_URL is unset or the bus is unreachable, the bridge stays in
# disconnected/mock mode and the existing demo signals continue to work.
# Subscribed subjects: KANNAKA.dreams, KANNAKA.consciousness, KANNAKA.reactions,
#   KANNAKA.exemplars, queen.event.dream.start|end, queen.event.join|leave.
# REQ/REPLY: KANNAKA.ask.<armId> for arm "Connection Test" (NATS-reachable arms).
NATS_URL=nats://swarm.ninja-portal.com:4222

# ── Kannaktopus wake bridge (optional) ──────────────────────────────────────
# When set, the "Wake Kannaktopus" demo button POSTs a wake signal to this URL
# in addition to spawning local demo tasks. Leave unset for mock mode (the
# button still pulls a fresh observatory snapshot for the HRM panel).
KANNAKTOPUS_WAKE_URL=
KANNAKTOPUS_API_KEY=

# ── Server ports (Replit assigns automatically) ─────────────────────────────
PORT=
