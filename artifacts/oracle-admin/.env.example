# ─────────────────────────────────────────────────────────────────────────────
# oracle-admin shim — environment variables
#
# Deploy this on the bare-metal Oracle host as user `opc`. See README.md for
# the systemd unit and sudoers configuration.
# ─────────────────────────────────────────────────────────────────────────────

# TCP port the shim listens on. Default 8090.
PORT=8090

# REQUIRED in production. Shared HMAC secret used to verify dispatch
# requests from QueenSync. MUST match QUEENSYNC_ORACLE_ADMIN_HMAC_SECRET on
# the QueenSync side. When unset, the shim refuses all dispatches with 503
# unless ORACLE_ADMIN_ALLOW_UNSIGNED=true is set (dev only).
QUEENSYNC_ORACLE_ADMIN_HMAC_SECRET=

# Dev escape hatch: when `true`, accept unsigned dispatches. NEVER set this
# on a public host — it disables the only authentication the shim has.
ORACLE_ADMIN_ALLOW_UNSIGNED=false

# Upstream HTTP endpoints the shim curls into.
RADIO_BASE_URL=https://radio.ninja-portal.com
OBSERVATORY_BASE_URL=https://observatory.ninja-portal.com
KANNAKA_DREAM_TRIGGER_URL=
KANNAKA_STATUS_URL=http://127.0.0.1:7777/status

# pino log level (debug | info | warn | error). Default info.
LOG_LEVEL=info
