# ─────────────────────────────────────────────────────────────────────────────
# oracle-admin shim — environment variables
#
# Deploy this on the bare-metal Oracle host as user `opc`. See README.md for
# the systemd unit and sudoers configuration.
# ─────────────────────────────────────────────────────────────────────────────

# TCP port the shim listens on. Default 8090.
PORT=8090

# Bind host. Defaults to 127.0.0.1 (loopback) — override only when fronted
# by a TLS-terminating reverse proxy or when the public firewall is closed
# to this port.
ORACLE_ADMIN_HOST=127.0.0.1

# REQUIRED in production. Shared HMAC secret used to verify dispatch
# requests from QueenSync. MUST match QUEENSYNC_ORACLE_ADMIN_HMAC_SECRET on
# the QueenSync side. When unset, the shim refuses all dispatches with 503
# unless ORACLE_ADMIN_ALLOW_UNSIGNED=true is set (dev only).
QUEENSYNC_ORACLE_ADMIN_HMAC_SECRET=

# Dev escape hatch: when `true`, accept unsigned dispatches. NEVER set this
# on a public host — it disables the only authentication the shim has.
ORACLE_ADMIN_ALLOW_UNSIGNED=false

# ─── Defence-in-depth (Wave 3 hardening) ────────────────────────────────────

# Comma-separated allowlist of source IPs allowed to hit /dispatch and
# /metrics. /healthz is always reachable so liveness probes work without
# being added here. When empty (default), every IP can connect — fine
# behind a private tunnel, NOT fine on a public bind. Set this to the
# QueenSync deploy IP on the public deploy. IPv4-mapped IPv6 addresses
# (::ffff:1.2.3.4) match the bare IPv4 entry.
#   Example: ORACLE_ADMIN_ALLOWED_IPS=203.0.113.7
ORACLE_ADMIN_ALLOWED_IPS=

# Set to `true` only when the shim is fronted by a trusted reverse proxy
# (nginx, caddy, Traefik). Honours X-Forwarded-For so req.ip / the
# allowlist see the real client IP instead of 127.0.0.1.
#
# SAFETY: only enable this when the direct shim port (8090 by default) is
# firewalled or bound to loopback / a private interface. If the port is
# reachable directly from the internet, a hostile client can send a
# forged X-Forwarded-For and bypass ORACLE_ADMIN_ALLOWED_IPS entirely.
ORACLE_ADMIN_TRUST_PROXY=false

# Per-source-IP cap on /dispatch. Default 5 dispatches per minute. Set to
# 0 to disable rate limiting entirely (NOT recommended on a public bind —
# a leaked HMAC secret could otherwise thrash the kannaka services).
ORACLE_ADMIN_RATE_LIMIT_PER_MIN=5

# Comma-separated allowlist of capabilities accepted on this host. When
# unset, all six capabilities are accepted. Useful to disable a single
# handler on a specific host without redeploying the shim.
#   Example (everything except dream_trigger):
#   ORACLE_ADMIN_ENABLED_CAPABILITIES=restart_radio,restart_observatory,trigger_oration_now,setOverride,kannaka_status
ORACLE_ADMIN_ENABLED_CAPABILITIES=

# ─── Upstream HTTP endpoints the shim curls into. ───────────────────────────

RADIO_BASE_URL=https://radio.ninja-portal.com
OBSERVATORY_BASE_URL=https://observatory.ninja-portal.com
KANNAKA_DREAM_TRIGGER_URL=
KANNAKA_STATUS_URL=http://127.0.0.1:7777/status

# pino log level (debug | info | warn | error). Default info.
LOG_LEVEL=info
